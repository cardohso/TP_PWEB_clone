  "components": {
    "schemas": {
      "Categoria": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nome": {
            "type": "string",
            "nullable": true
          },
          "produtos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Produto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CriarPagamentoRequest": {
        "required": [
          "clienteId",
          "metodoPagamento",
          "produtos"
        ],
        "type": "object",
        "properties": {
          "clienteId": {
            "minLength": 1,
            "type": "string"
          },
          "metodoPagamento": {
            "minLength": 1,
            "type": "string"
          },
          "produtos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProdutoPedido"
            }
          }
        },
        "additionalProperties": false
      },
      "LoginModel": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ModoEntrega": {
        "required": [
          "nome"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nome": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "detalhe": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "Produto": {
        "required": [
          "detalhe",
          "nome",
          "preco",
          "urlImagem"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nome": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "detalhe": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "origem": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "titulo": {
            "type": "string",
            "nullable": true
          },
          "urlImagem": {
            "maxLength": 200,
            "minLength": 0,
            "type": "string"
          },
          "preco": {
            "type": "number",
            "format": "double"
          },
          "promocao": {
            "type": "boolean"
          },
          "maisVendido": {
            "type": "boolean"
          },
          "emStock": {
            "type": "number",
            "format": "double"
          },
          "disponivel": {
            "type": "boolean"
          },
          "modoentrega": {
            "$ref": "#/components/schemas/ModoEntrega"
          },
          "categoria": {
            "$ref": "#/components/schemas/Categoria"
          },
          "imagem": {
            "type": "string",
            "format": "byte",
            "nullable": true
          },
          "imageFile": {
            "type": "string",
            "format": "binary",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ProdutoPedido": {
        "required": [
          "id",
          "quantidade"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "quantidade": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Utilizador": {
        "required": [
          "apelido",
          "email",
          "nome",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "nome": {
            "minLength": 1,
            "type": "string"
          },
          "apelido": {
            "minLength": 1,
            "type": "string"
          },
          "nif": {
            "type": "string",
            "nullable": true
          },
          "rua": {
            "type": "string",
            "nullable": true
          },
          "localidade1": {
            "type": "string",
            "nullable": true
          },
          "localidade2": {
            "type": "string",
            "nullable": true
          },
          "pais": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "Insira o token JWT no formato: Bearer {seu_token}",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}