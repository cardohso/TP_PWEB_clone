@page "/login"
@using RCLAPI.DTO
@using System.ComponentModel.DataAnnotations
@inject IApiServices apiService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<h3>Login</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p style="color:red">@errorMessage</p>
}

<EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div>
        <label for="email">Email</label>
        <InputText id="email" @bind-Value="loginModel.Email" />
    </div>
    <div>
        <label for="password">Senha</label>
        <InputText id="password" @bind-Value="loginModel.Password" type="password" />
    </div>
    <button type="submit">Login</button>
</EditForm>

@code {
    private LoginModel loginModel = new LoginModel();
    private string errorMessage;

    private async Task HandleLogin()
    {
        Console.WriteLine("Formulário de login submetido!");

        try
        {
            var result = await apiService.Login(loginModel);


            if (result != null)
            {
                Console.WriteLine("Login bem-sucedido!");
                NavigationManager.NavigateTo("/");
            }
            
            else
            {
                errorMessage = "Credenciais inválidas";
                Console.WriteLine("Login inválido.");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao tentar login: {ex.Message}";
            Console.WriteLine($"Erro ao tentar login: {ex.Message}");
        }
    }



    public class LoginResult
    {
        public string AccessToken { get; set; }
        public string TokenType { get; set; }
    }
}
