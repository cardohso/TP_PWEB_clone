        }

    .botoes {
        margin-top: 15px;
    }

    .mensagem-erro {
        color: red;
        font-size: 14px;
        margin-bottom: 10px;
    }
</style>

<script>
    function sortTable(columnIndex, tableId) {
        const table = document.getElementById(tableId);
        const rows = Array.from(table.rows).slice(1); // Exclude the header row
        const isAscending = table.getAttribute(`data-sort-dir-${columnIndex}`) === "asc"; // Track sort direction per column
        const direction = isAscending ? -1 : 1;

        rows.sort((rowA, rowB) => {
            let cellA = rowA.cells[columnIndex].textContent.trim();
            let cellB = rowB.cells[columnIndex].textContent.trim();

            // Detect and handle numeric sorting
            const numA = parseFloat(cellA.replace(/[^0-9.-]+/g, ""));
            const numB = parseFloat(cellB.replace(/[^0-9.-]+/g, ""));
            const isNumber = !isNaN(numA) && !isNaN(numB);

            if (isNumber) {
                return (numA - numB) * direction;
            }

            // Default to case-insensitive string comparison
            cellA = cellA.toLowerCase();
            cellB = cellB.toLowerCase();

            if (cellA < cellB) return -1 * direction;
            if (cellA > cellB) return 1 * direction;
            return 0;
        });

        // Append sorted rows back to the table
        table.tBodies[0].append(...rows);

        // Update sort direction for this column
        table.setAttribute(`data-sort-dir-${columnIndex}`, isAscending ? "desc" : "asc");
    }
</script>