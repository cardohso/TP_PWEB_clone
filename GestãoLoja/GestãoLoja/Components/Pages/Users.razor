@page "/usersAdminGestor"
@using Microsoft.AspNetCore.Identity
@using GestãoLoja.Data
@using GestãoLoja.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]

<h3 class="titulo">Gestão de Usuários</h3>

<div class="container">
    <!-- Filter by Roles -->
    <div class="filter-container">
        <label for="roleFilter">Filtrar por roles:</label>
        <select id="roleFilter" onchange="filterByRole()">
            <option value="">*Todos*</option>
            @foreach (var role in RoleList)
            {
                <option value="@role">@role</option>
            }
        </select>
    </div>

    <!-- Tabela de Usuários -->
    <table class="tabela" id="userTable">
        <thead>
            <tr>
                <th onclick="sortTable(0)">Id</th>
                <th onclick="sortTable(1)">Email</th>
                <th onclick="sortTable(2)">Nome de Usuário</th>
                <th onclick="sortTable(3)">Roles</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in UserList)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Email</td>
                    <td>@user.UserName</td>
                    <td>@string.Join(", ", user.Roles)</td>
                    <td>
                        <button @onclick="() => DeleteUser(user.Id)" disabled="@user.Roles.Contains("Admin")">Delete</button>
                        <button @onclick="() => DeactivateUser(user.Id)" disabled="@user.Roles.Contains("Admin")">Deactivate</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<UserWithRoles> UserList = new();
    private List<string> RoleList = new(); // List to hold unique roles

    protected override async Task OnInitializedAsync()
    {
        var users = await UserManager.Users.ToListAsync();
        foreach (var user in users)
        {
            var roles = await UserManager.GetRolesAsync(user);
            if (roles.Contains("Admin") || roles.Contains("Gestor"))
            {
                UserList.Add(new UserWithRoles
                    {
                        Id = user.Id,
                        Email = user.Email,
                        UserName = user.UserName,
                        Roles = roles.ToList()
                    });

                // Add roles to the RoleList (no duplicates)
                foreach (var role in roles)
                {
                    if (!RoleList.Contains(role))
                    {
                        RoleList.Add(role);
                    }
                }
            }
        }
    }

    // Method to delete a user
    private async Task DeleteUser(string userId)
    {
        var user = await UserManager.FindByIdAsync(userId);
        if (user != null)
        {
            var roles = await UserManager.GetRolesAsync(user);
            // Prevent deletion if the user has an "Admin" role
            if (!roles.Contains("Admin"))
            {
                var result = await UserManager.DeleteAsync(user);
                if (result.Succeeded)
                {
                    // Remove the user from the UserList
                    UserList.RemoveAll(u => u.Id == userId);
                    StateHasChanged(); // Refresh the UI
                }
                else
                {
                    // Handle deletion failure (you can add error messages here)
                    Console.WriteLine("Error deleting user");
                }
            }
        }
    }

    // Method to deactivate a user
    private async Task DeactivateUser(string userId)
    {
        var user = await UserManager.FindByIdAsync(userId);
        if (user != null)
        {
            var roles = await UserManager.GetRolesAsync(user);
            // Prevent deactivation if the user has an "Admin" role
            if (!roles.Contains("Admin"))
            {
                user.LockoutEnabled = true;
                user.LockoutEnd = DateTimeOffset.MaxValue;
                var result = await UserManager.UpdateAsync(user);
                if (result.Succeeded)
                {
                    // Optionally, update the UserList to reflect the deactivation
                    StateHasChanged(); // Refresh the UI
                }
                else
                {
                    // Handle deactivation failure (you can add error messages here)
                    Console.WriteLine("Error deactivating user");
                }
            }
        }
    }

    public class UserWithRoles
    {
        public string Id { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public List<string> Roles { get; set; } = new();
    }
}

<style>
    /* Estilos gerais */
    .titulo {
        text-align: center;
        margin-bottom: 20px;
        font-size: 28px;
        color: #333;
    }

    .container {
        width: 80%;
        margin: 0 auto;
        padding: 20px;
        background-color: #f9f9f9;
        border-radius: 8px;
    }

    /* Estilo da tabela */
    .tabela {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
    }

        .tabela th, .tabela td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        .tabela th {
            background-color: #007BFF;
            color: white;
            cursor: pointer;
        }

    /* Style for the filter container */
    .filter-container {
        margin-bottom: 20px;
        font-size: 16px;
    }

        .filter-container select {
            padding: 5px;
            font-size: 16px;
        }
</style>

<script>
    function sortTable(columnIndex) {
        const table = document.getElementById("userTable");
        const rows = Array.from(table.rows).slice(1);
        const isAscending = table.getAttribute("data-sort-dir") === "asc";
        const direction = isAscending ? -1 : 1;

        rows.sort((rowA, rowB) => {
            const cellA = rowA.cells[columnIndex].textContent.trim().toLowerCase();
            const cellB = rowB.cells[columnIndex].textContent.trim().toLowerCase();

            if (cellA < cellB) return -1 * direction;
            if (cellA > cellB) return 1 * direction;
            return 0;
        });

        table.tBodies[0].append(...rows);
        table.setAttribute("data-sort-dir", isAscending ? "desc" : "asc");
    }

    // Function to filter users by role
    function filterByRole() {
        const selectedRole = document.getElementById("roleFilter").value;
        const table = document.getElementById("userTable");
        const rows = Array.from(table.rows).slice(1);

        rows.forEach(row => {
            const roles = row.cells[3].textContent.trim().toLowerCase(); // Get the roles from the Roles column
            if (selectedRole === "" || roles.includes(selectedRole.toLowerCase())) {
                row.style.display = ""; // Show the row
            } else {
                row.style.display = "none"; // Hide the row
            }
        });
    }
</script>