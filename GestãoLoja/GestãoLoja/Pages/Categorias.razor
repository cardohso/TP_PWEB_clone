@page "/categorias"
@using GestãoLoja.Entities
@using Microsoft.EntityFrameworkCore
@inject Data.ApplicationDbContext DbContext
@inject Entities.Categoria Categoria

<h3>Gestão de Categorias</h3>

<table>
    <thead>
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var categoria in categorias)
        {
            <tr>
                <td>@categoria.Id</td>
                <td>@categoria.Nome</td>
                <td>
                    <button @onclick="() => EditarCategoria(categoria)">Editar</button>
                    <button @onclick="() => ExcluirCategoria(categoria.Id)">Excluir</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<button @onclick="NovaCategoria">Nova Categoria</button>

@if (Editando)
{
    <div>
        <h4>Editar Categoria</h4>
        <label>Nome:</label>
        <input @bind="CategoriaAtual.Nome" />
        <button @onclick="SalvarCategoria">Salvar</button>
        <button @onclick="CancelarEdicao">Cancelar</button>
    </div>
}

@code {
    private List<Categoria> categorias = new();
    private Categoria CategoriaAtual = new Categoria();
    private bool Editando = false;

    protected override async Task OnInitializedAsync()
    {
        categorias = await DbContext.Categorias.ToListAsync();
    }

    private void NovaCategoria()
    {
        CategoriaAtual = new Categoria();
        Editando = true;
    }

    private void EditarCategoria(Categoria categoria)
    {
        CategoriaAtual = categoria;
        Editando = true;
    }

    private async Task ExcluirCategoria(int id)
    {
        var categoria = await DbContext.Categorias.FindAsync(id);
        if (categoria != null)
        {
            DbContext.Categorias.Remove(categoria);
            await DbContext.SaveChangesAsync();
            categorias = await DbContext.Categorias.ToListAsync();
        }
    }

    private async Task SalvarCategoria()
    {
        if (CategoriaAtual.Id == 0)
            DbContext.Categorias.Add(CategoriaAtual);
        else
            DbContext.Categorias.Update(CategoriaAtual);

        await DbContext.SaveChangesAsync();
        categorias = await DbContext.Categorias.ToListAsync();
        Editando = false;
    }

    private void CancelarEdicao()
    {
        CategoriaAtual = new Categoria();
        Editando = false;
    }
}
